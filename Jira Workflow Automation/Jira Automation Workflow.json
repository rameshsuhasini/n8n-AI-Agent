      "parameters": {
        "jsCode": "const comments = $input.all();\nconst original = $('Has Jira ID?').item.json;\n\nif (comments.length === 0) {\n  return [{ json: { ...original, isDuplicate: false } }];\n}\n\nconst lastComment = comments[0].json;\nconst lastTime = new Date(lastComment.created).getTime();\nconst now = new Date().getTime();\nconst minutesSinceLastComment = (now - lastTime) / 1000 / 60;\n\nreturn [{ json: { \n  ...original,\n  isDuplicate: minutesSinceLastComment < 10\n}}];"
      },
