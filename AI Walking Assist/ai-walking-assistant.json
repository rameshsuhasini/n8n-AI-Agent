        "jsCode": "// Get input data\nconst weather = $json.weather?.[0]?.main || 'Clear';\nconst temperature = $json.main?.temp || 15;\n\n// Trails from Google Sheets\nconst trails = items.map(item => item.json);\n\n// Simple rule-based selection\nlet selectedTrail;\n\nif (weather === 'Rain') {\n  selectedTrail = trails.find(t => Number(t.Miles) <= 2) || trails[0];\n} else {\n  selectedTrail = trails.find(t => Number(t.Miles) <= 4) || trails[0];\n}\n\n// Return ONE item only\nreturn [\n  {\n    json: {\n      weatherSummary: weather,\n      temperature,\n      ...selectedTrail\n    }\n  }\n];\n"
