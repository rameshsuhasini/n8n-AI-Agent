      "parameters": {
        "jsCode": "// Check if Claude API failed\nconst claudeFailed = $json.error !== undefined || !$json.content;\n\nlet aiSummary;\nif (claudeFailed) {\n  // Fallback — use raw commit message\n  const original = $('Skip if Duplicate').first()?.json || {};\n  aiSummary = original.commitMessage || \"No summary available\";\n} else {\n  aiSummary = $json.content?.[0]?.text || \"No summary available\";\n}\n\nconst original = $('Skip if Duplicate').first()?.json || {};\n\nreturn [{\n  jiraId: original.jiraId,\n  author: original.author,\n  timestamp: original.timestamp,\n  url: original.url,\n  commitMessage: original.commitMessage,\n  aiSummary: aiSummary,\n  eventType: original.eventType\n}];"
      },
