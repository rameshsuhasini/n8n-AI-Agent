    {
      "parameters": {
        "jsCode": "const data = $json.body || $json;\nconst pr = data.pull_request || {};\nconst action = data.action || '';\nconst branch = pr.head?.ref || '';\nconst jiraPattern = /([A-Z]+-\\d+)/g;\nconst sources = [branch, pr.title || '', pr.body || ''].join(' ');\nconst tickets = [...new Set(sources.match(jiraPattern) || [])];\n\nif (tickets.length === 0) return [];\n\nconst merged = pr.merged || false;\nlet eventType = 'pr_opened';\nif (action === 'closed' && merged) eventType = 'pr_merged';\nelse if (action === 'closed' && !merged) return [];\n\nreturn tickets.map(id => ({ json: {\n  jiraId: id,\n  commitMessage: pr.title || '',\n  author: pr.user?.login || 'Unknown',\n  timestamp: new Date().toISOString(),\n  url: pr.html_url || '',\n  eventType,\n  repoName: data.repository?.name || '',\n  prNumber: pr.number || null\n}}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1280,
        -240
      ],
      "id": "a4280865-e761-4e02-9987-a7b5016a544b",
      "name": "Extract from PR"
    },
    {
      "parameters": {
        "jsCode": "const data = $json.body || $json;\nconst message = data.head_commit?.message || \"\";\nconst ref = data.ref || \"\";\nconst before = data.before || \"\";\nconst isBranchCreation = before === \"0000000000000000000000000000000000000000\";\nconst branchName = ref.replace(\"refs/heads/\", \"\");\nconst cleanMessage = message.split(\"Co-Authored-By\")[0].trim();\n\n// Skip merge commits — already handled by the pull_request event\nif (cleanMessage.startsWith(\"Merge pull request\")) {\n  return [];\n}\n\nif (isBranchCreation) {\n  const jiraId = branchName.match(/[A-Z]+-\\d+/)?.[0] || null;\n  return [{\n    jiraId: jiraId,\n    commitMessage: `Branch created: ${branchName}`,\n    author: data.sender?.login || data.pusher?.name || \"Unknown\",\n    timestamp: new Date().toISOString(),\n    url: data.repository?.html_url || \"\",\n    eventType: \"branch_created\"\n  }];\n}\n\nconst jiraId = cleanMessage.match(/[A-Z]+-\\d+/)?.[0] || null;\nreturn [{\n  jiraId: jiraId,\n  commitMessage: cleanMessage,\n  author: data.head_commit?.author?.name || \"Unknown\",\n  timestamp: data.head_commit?.timestamp || \"\",\n  url: data.head_commit?.url || \"\",\n  eventType: \"push\"\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
