    {
      "parameters": {
        "jsCode": "const data = $json.body || $json;\nif (data.ref_type !== 'branch') return [];\nconst branch = data.ref || '';\nconst jiraPattern = /([A-Z]+-\\d+)/g;\nconst tickets = [...new Set(branch.match(jiraPattern) || [])];\nif (tickets.length === 0) return [];\nreturn tickets.map(id => ({ json: {\n  jiraId: id,\n  commitMessage: `Branch created: ${branch}`,\n  author: data.sender?.login || 'Unknown',\n  timestamp: new Date().toISOString(),\n  url: data.repository?.html_url || '',\n  eventType: 'branch_created'\n}}));"
      },
